# Server Configuration
HOST=0.0.0.0
PORT=8000

# Session Configuration
DEFAULT_WORKING_DIR=~/cloude-projects
SESSION_TIMEOUT=3600

# Claude CLI Configuration
# Path to the Claude CLI binary. If not set, will auto-detect using:
# 1. `which claude` (if in PATH)
# 2. ~/.claude/local/claude
# 3. Fallback to just "claude"
CLAUDE_CLI_PATH=/path/to/claude

# Logging
LOG_BUFFER_SIZE=1000
LOG_FILE_RETENTION=7
LOG_DIRECTORY=/tmp/cloude-code-logs

# Tunnels
TUNNEL_PROVIDER=cloudflare
AUTO_CREATE_TUNNELS=true
TUNNEL_TIMEOUT=30
USE_NAMED_TUNNELS=true

# --- Optional: Cloudflare public tunnel (disabled by default) ---
# Cloude Code ships in LAN-only mode by default (tunnel backend =
# local_only). To expose the server to the public internet through a
# Cloudflare tunnel, set tunnel.backend to 'quick_cloudflare' or
# 'named_cloudflare' in config.json AND set tunnel.enable_cloudflare=true.
# Then populate the values below.
#
# Get API token from: https://dash.cloudflare.com/profile/api-tokens
# Create token with "Zone.DNS Edit" and "Cloudflare Tunnel Edit" permissions.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=your-subdomain.yourdomain.com
CLOUDFLARE_TUNNEL_NAME=claude-tunnel
CLOUDFLARE_TUNNEL_ID=
# --- End Cloudflare section ---

# Security (Optional)
API_KEY=
# ALLOWED_ORIGINS defaults to ["*"] - only set if you need to restrict origins

# Authentication Secrets
# Generated by setup_auth.py - DO NOT COMMIT THESE VALUES
TOTP_SECRET=
JWT_SECRET=

# Authentication Configuration
# Path to config.json (contains projects, template_path, etc - NOT secrets)
AUTH_CONFIG_FILE=./config.json

# --- Docker (Mode 2) ---
# Set to a specific LAN IP (not 0.0.0.0) to expose only on your home network.
# Run scripts/preflight-bind-ip.sh to list available IPs.
# Default 127.0.0.1 keeps it loopback-only if unset.
CLOUDE_BIND_IP=127.0.0.1
# Host path to mount as /workspace inside the container
CLOUDE_PROJECT_PATH=./projects
# Host path for logs / session metadata / refresh_tokens.db
CLOUDE_LOG_DIR=./logs
# User ID mapping — export these before docker compose build to match host perms:
#   UID=$(id -u) GID=$(id -g) docker compose build

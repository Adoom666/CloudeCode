{
  "name": "cloude-code-menubar",
  "version": "0.5.0",
  "description": "macOS menu bar app for Cloude Code remote control",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "package": "electron-builder --mac --publish never"
  },
  "keywords": [
    "electron",
    "menubar",
    "claude",
    "macos"
  ],
  "author": "Cloude Code",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.2"
  },
  "build": {
    "appId": "com.cloudecode.menubar",
    "productName": "Cloude Code",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../src",
        "to": "src",
        "filter": ["**/*"]
      },
      {
        "from": "../client",
        "to": "client",
        "filter": ["**/*"]
      },
      {
        "from": "../requirements.txt",
        "to": "requirements.txt"
      },
      {
        "from": "../setup_auth.py",
        "to": "setup_auth.py"
      },
      {
        "from": "../config.example.json",
        "to": "config.example.json"
      },
      {
        "from": "../nuke.sh",
        "to": "nuke.sh"
      },
      {
        "from": "../.env.example",
        "to": ".env.example"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "Cloude Code ${version}",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 200,
          "type": "file"
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "iconSize": 100,
      "iconTextSize": 14,
      "format": "UDZO"
    }
  }
}
